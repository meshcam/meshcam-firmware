; Copy to secrets.ini (gitignored) and fill in. Referenced by platformio.ini.
; The WiFi gateways try GW_WIFI_SSID first, then GW_WIFI_SSID2 (optional fallback);
; the poe-* (ethernet) envs ignore the WiFi pairs but the defines are harmless.
; ota_auth must match GW_OTA_PASS — the espota upload envs read it.
[secrets]
ota_auth = change-me-ota
build_flags =
	'-DGW_WIFI_SSID="your-primary-ssid"'
	'-DGW_WIFI_PSK="..."'
	'-DGW_WIFI_SSID2="your-fallback-ssid"'
	'-DGW_WIFI_PSK2="..."'
	'-DGW_INGEST_URL="https://trailcam.example.com/api/v1/ingest"'
	'-DGW_INGEST_TOKEN="tc_..."'
	'-DGW_VIEW_HOST="trailcam.example.com"'
	'-DGW_OTA_PASS="change-me-ota"'
